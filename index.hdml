  </section>

  <!-- ══════ WHAT I DO ══════ -->
  <section class="section reveal">
    <div class="sec-label">// day to day</div>
    <h2 class="sec-title">What I <span>Work On</span></h2>
    <table class="do-table">
      <tr><td>RTL Design</td><td>Write synthesisable modules in Verilog/SV — ALUs, FIFOs, FSMs, barrel shifters, pipeline stages</td></tr>
      <tr><td>Testbench</td><td>Build <strong>directed &amp; constrained-random</strong> testbenches with reusable driver/monitor/scoreboard components</td></tr>
      <tr><td>Coverage</td><td>Define covergroups, coverpoints &amp; cross-coverage for <strong>functional coverage closure</strong></td></tr>
      <tr><td>Assertions</td><td>Write SVA <code style="color:var(--blue3);font-size:12px">assert / assume / cover</code> properties for protocol checks</td></tr>
      <tr><td>Synthesis</td><td>Run logic synthesis with <strong>Cadence Genus</strong>, analyse critical paths &amp; area/power trade-offs</td></tr>
      <tr><td>HDLBits</td><td>Solve Verilog problems daily — combinational, sequential, FSMs, Karnaugh maps</td></tr>
    </table>
  </section>

  <!-- ══════ PROJECTS ══════ -->
  <section class="section reveal">
    <div class="sec-label">// github.com/vinodgaddam1</div>
    <h2 class="sec-title">Featured <span>Projects</span></h2>
    <div class="proj-grid">
      <a class="proj-card" href="https://github.com/vinodgaddam1/vlsi-rtl-designs" target="_blank">
        <div class="proj-header"><div class="proj-dot"></div><div class="proj-name">VLSI RTL Designs</div></div>
        <div class="proj-desc">Synthesisable Verilog modules — ALU, FIFO, barrel shifter, priority encoder, FSM controllers — each with a ModelSim testbench and waveform screenshots.</div>
        <div class="proj-tags"><span class="ptag">Verilog</span><span class="ptag">ModelSim</span><span class="ptag">RTL</span><span class="ptag">FSM</span></div>
      </a>
      <a class="proj-card" href="https://github.com/vinodgaddam1/sv-verification-env" target="_blank">
        <div class="proj-header"><div class="proj-dot" style="background:#00e5a0"></div><div class="proj-name">SV Verification Env</div></div>
        <div class="proj-desc">SystemVerilog testbench for an AHB-lite slave — constrained-random stimulus, covergroups, SVA protocol assertions, and self-checking scoreboard.</div>
        <div class="proj-tags"><span class="ptag">SystemVerilog</span><span class="ptag">SVA</span><span class="ptag">Coverage</span><span class="ptag">AHB</span></div>
      </a>
      <a class="proj-card" href="https://github.com/vinodgaddam1/asic-synthesis-flow" target="_blank">
        <div class="proj-header"><div class="proj-dot" style="background:#c084fc"></div><div class="proj-name">ASIC Synthesis Flow</div></div>
        <div class="proj-desc">RTL-to-gate synthesis of a pipelined multiplier using Cadence Genus — SDC constraints, timing path analysis, area/power study, gate-level netlist.</div>
        <div class="proj-tags"><span class="ptag">Cadence Genus</span><span class="ptag">STA</span><span class="ptag">SDC</span><span class="ptag">ASIC</span></div>
      </a>
      <a class="proj-card" href="https://github.com/vinodgaddam1/hdlbits-solutions" target="_blank">
        <div class="proj-header"><div class="proj-dot" style="background:#fcd34d"></div><div class="proj-name">HDLBits Solutions</div></div>
        <div class="proj-desc">100+ Verilog solutions to HDLBits — combinational logic, sequential circuits, FSMs, Karnaugh maps and timing diagrams with explanatory comments.</div>
        <div class="proj-tags"><span class="ptag">Verilog</span><span class="ptag">HDLBits</span><span class="ptag">Digital Logic</span></div>
      </a>
    </div>
  </section>

  <!-- ══════ GITHUB STATS ══════ -->
