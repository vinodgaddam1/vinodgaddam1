<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Gaddam Vinod Kumar | VLSI RTL Design & Verification</title>
<link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#060e1a;
  --bg2:#0b1728;
  --bg3:#0f2040;
  --blue:#1a73e8;
  --blue2:#4a9cf6;
  --blue3:#7ab8ff;
  --green:#00e5a0;
  --text:#e8f0fe;
  --muted:#7a9cc4;
  --border:rgba(26,115,232,0.18);
  --card:rgba(11,23,40,0.85);
  --font-code:'Fira Code',monospace;
  --font-body:'Inter',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  background:var(--bg);
  color:var(--text);
  font-family:var(--font-body);
  overflow-x:hidden;
  min-height:100vh;
}

/* ── CANVAS BACKGROUND ── */
#bg-canvas{
  position:fixed;top:0;left:0;width:100%;height:100%;
  z-index:0;pointer-events:none;
}

/* ── LAYOUT ── */
.page{position:relative;z-index:1;max-width:980px;margin:0 auto;padding:0 24px 80px;}

/* ── HERO ── */
.hero{
  min-height:100vh;
  display:flex;flex-direction:column;
  justify-content:center;align-items:flex-start;
  padding:80px 0 60px;
  position:relative;
}
.hero-eyebrow{
  font-family:var(--font-code);
  font-size:12px;color:var(--green);
  letter-spacing:3px;text-transform:uppercase;
  margin-bottom:20px;
  opacity:0;animation:fadeUp 0.6s 0.2s forwards;
}
.hero-name{
  font-size:clamp(36px,6vw,72px);
  font-weight:600;line-height:1.05;
  letter-spacing:-1px;
  opacity:0;animation:fadeUp 0.6s 0.4s forwards;
}
.hero-name span{color:var(--blue2)}
.hero-role{
  font-family:var(--font-code);
  font-size:clamp(14px,2vw,20px);
  color:var(--blue3);
  margin-top:16px;min-height:30px;
  opacity:0;animation:fadeUp 0.6s 0.6s forwards;
}
.cursor-blink{
  display:inline-block;width:2px;height:1.1em;
  background:var(--blue2);margin-left:2px;
  vertical-align:middle;
  animation:blink 1s step-end infinite;
}
.hero-desc{
  max-width:560px;
  font-size:15px;color:var(--muted);line-height:1.8;
  margin-top:24px;
  opacity:0;animation:fadeUp 0.6s 0.8s forwards;
}
.hero-desc strong{color:var(--text);font-weight:500}
.hero-cta{
  display:flex;flex-wrap:wrap;gap:12px;
  margin-top:36px;
  opacity:0;animation:fadeUp 0.6s 1s forwards;
}
.btn{
  display:inline-flex;align-items:center;gap:8px;
  padding:11px 22px;border-radius:6px;
  font-size:13px;font-weight:500;
  text-decoration:none;cursor:pointer;
  transition:all 0.2s;border:none;
  font-family:var(--font-body);
}
.btn-primary{background:var(--blue);color:#fff}
.btn-primary:hover{background:var(--blue2);transform:translateY(-1px)}
.btn-outline{
  background:transparent;color:var(--blue2);
  border:1px solid rgba(74,156,246,0.4);
}
.btn-outline:hover{background:rgba(26,115,232,0.1);border-color:var(--blue2)}
.btn-ghost{
  background:transparent;color:var(--muted);
  border:1px solid var(--border);
}
.btn-ghost:hover{color:var(--text);border-color:rgba(26,115,232,0.4)}
.scroll-hint{
  position:absolute;bottom:40px;left:0;
  display:flex;align-items:center;gap:10px;
  font-size:11px;color:var(--muted);letter-spacing:2px;
  font-family:var(--font-code);
  opacity:0;animation:fadeUp 0.6s 1.4s forwards;
}
.scroll-arrow{
  width:20px;height:20px;border-right:1px solid var(--muted);
  border-bottom:1px solid var(--muted);
  transform:rotate(45deg);
  animation:bounce 2s ease-in-out infinite;
}

/* ── SECTION ── */
.section{padding:80px 0;border-top:1px solid var(--border)}
.sec-label{
  font-family:var(--font-code);
  font-size:11px;color:var(--green);
  letter-spacing:3px;text-transform:uppercase;
  margin-bottom:10px;
}
.sec-title{
  font-size:clamp(22px,3vw,32px);
  font-weight:600;
  margin-bottom:40px;
  line-height:1.2;
}
.sec-title span{color:var(--blue2)}

/* ── SKILL BLOCKS ── */
.skill-domains{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px}
.skill-domain{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:12px;padding:24px;
  transition:border-color 0.2s,transform 0.2s;
}
.skill-domain:hover{border-color:rgba(26,115,232,0.5);transform:translateY(-2px)}
.domain-icon{font-size:24px;margin-bottom:12px}
.domain-name{
  font-size:14px;font-weight:600;
  color:var(--blue2);margin-bottom:16px;
  font-family:var(--font-code);
}
.skill-tags{display:flex;flex-wrap:wrap;gap:7px}
.tag{
  font-size:11px;padding:4px 10px;border-radius:4px;
  font-family:var(--font-code);font-weight:500;
}
.tag-hdl{background:rgba(26,115,232,0.15);color:var(--blue3);border:1px solid rgba(26,115,232,0.3)}
.tag-ver{background:rgba(0,229,160,0.08);color:#5de8b8;border:1px solid rgba(0,229,160,0.2)}
.tag-asic{background:rgba(147,51,234,0.12);color:#c084fc;border:1px solid rgba(147,51,234,0.25)}
.tag-tool{background:rgba(234,179,8,0.1);color:#fcd34d;border:1px solid rgba(234,179,8,0.2)}
.tag-os{background:rgba(100,116,139,0.15);color:#94a3b8;border:1px solid rgba(100,116,139,0.25)}

/* ── WHAT I DO TABLE ── */
.do-table{width:100%;border-collapse:collapse}
.do-table tr{border-bottom:1px solid var(--border)}
.do-table tr:last-child{border-bottom:none}
.do-table td{padding:16px 12px;font-size:14px;vertical-align:top}
.do-table td:first-child{
  font-family:var(--font-code);color:var(--blue2);
  font-size:12px;white-space:nowrap;width:180px;
  padding-right:24px;font-weight:500;
}
.do-table td:last-child{color:var(--muted);line-height:1.7}
.do-table td:last-child strong{color:var(--text);font-weight:500}

/* ── PROJECTS ── */
.proj-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px}
.proj-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:12px;padding:24px;
  transition:border-color 0.2s,transform 0.2s;
  text-decoration:none;color:inherit;display:block;
}
.proj-card:hover{border-color:rgba(26,115,232,0.5);transform:translateY(-3px)}
.proj-header{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.proj-dot{width:8px;height:8px;border-radius:50%;background:var(--blue2);flex-shrink:0}
.proj-name{font-size:15px;font-weight:600;color:var(--blue3)}
.proj-desc{font-size:13px;color:var(--muted);line-height:1.7;margin-bottom:16px}
.proj-tags{display:flex;flex-wrap:wrap;gap:6px}
.ptag{
  font-size:10px;padding:3px 8px;border-radius:3px;
  font-family:var(--font-code);
  background:rgba(26,115,232,0.12);
  color:var(--blue3);border:1px solid rgba(26,115,232,0.25);
}

/* ── STATS ── */
.stat-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px;margin-bottom:32px}
.stat-box{
  background:var(--card);border:1px solid var(--border);
  border-radius:10px;padding:20px 16px;text-align:center;
}
.stat-n{font-size:32px;font-weight:600;color:var(--blue2);line-height:1;font-family:var(--font-code)}
.stat-l{font-size:11px;color:var(--muted);margin-top:6px;letter-spacing:1px;text-transform:uppercase}

/* ── CONTRIB GRID ── */
.contrib-wrap{
  background:var(--card);border:1px solid var(--border);
  border-radius:12px;padding:20px;
}
.contrib-label{font-size:11px;color:var(--muted);margin-bottom:12px;font-family:var(--font-code)}
#contrib-grid{display:grid;grid-template-columns:repeat(53,1fr);gap:2px}
.contrib-cell{aspect-ratio:1;border-radius:2px}

/* ── LANG BARS ── */
.lang-list{display:flex;flex-direction:column;gap:14px}
.lang-row-item{display:flex;align-items:center;gap:14px}
.lang-name-cell{font-size:13px;font-family:var(--font-code);color:var(--text);min-width:130px}
.lang-track{flex:1;height:6px;background:rgba(255,255,255,0.06);border-radius:3px;overflow:hidden}
.lang-fill{height:100%;border-radius:3px;transition:width 1.4s cubic-bezier(.4,0,.2,1)}
.lang-pct{font-size:12px;color:var(--muted);min-width:36px;text-align:right;font-family:var(--font-code)}

/* ── CONNECT ── */
.connect-grid{display:flex;flex-wrap:wrap;gap:12px}
.connect-card{
  display:flex;align-items:center;gap:12px;
  padding:14px 20px;border-radius:10px;
  background:var(--card);border:1px solid var(--border);
  text-decoration:none;color:var(--text);
  transition:all 0.2s;min-width:180px;
}
.connect-card:hover{border-color:rgba(74,156,246,0.5);transform:translateY(-2px)}
.connect-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.connect-info{}
.connect-name{font-size:13px;font-weight:500}
.connect-sub{font-size:11px;color:var(--muted);margin-top:2px;font-family:var(--font-code)}

/* ── FOOTER ── */
footer{
  text-align:center;padding:40px 0 20px;
  border-top:1px solid var(--border);
  font-size:12px;color:var(--muted);
  font-family:var(--font-code);
  line-height:2;
}
footer em{color:var(--blue3);font-style:normal}

/* ── ANIMATIONS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
@keyframes bounce{0%,100%{transform:rotate(45deg) translateY(0)}50%{transform:rotate(45deg) translateY(5px)}}

.reveal{opacity:0;transform:translateY(24px);transition:opacity 0.6s ease,transform 0.6s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ── RESPONSIVE ── */
@media(max-width:600px){
  .page{padding:0 16px 60px}
  .hero{padding:60px 0 40px}
  .do-table td:first-child{width:120px;font-size:11px}
  #contrib-grid{grid-template-columns:repeat(26,1fr)}
}
</style>
</head>
<body>

<canvas id="bg-canvas"></canvas>

<div class="page">

  <!-- ══════ HERO ══════ -->
  <section class="hero">
    <div class="hero-eyebrow">// vinodgaddam1 · ECE Final Year · VLSI</div>
    <h1 class="hero-name">Gaddam<br/><span>Vinod Kumar</span></h1>
    <div class="hero-role" id="typed-role"><span class="cursor-blink"></span></div>
    <p class="hero-desc">
      Focused on <strong>RTL Design</strong> and <strong>Functional Verification</strong> —
      writing synthesisable Verilog &amp; SystemVerilog, building constrained-random testbenches
      with SVA assertions and functional coverage, and studying the full
      <strong>ASIC flow</strong> through Cadence Genus.
      Active <strong>HDLBits</strong> practitioner. Seeking VLSI internships &amp; full-time roles.
    </p>
    <div class="hero-cta">
      <a class="btn btn-primary" href="https://linkedin.com/in/vinod-kumar-gaddam-065080273" target="_blank">LinkedIn</a>
