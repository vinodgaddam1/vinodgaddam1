<script>
/* ── PARTICLE CANVAS ── */
const canvas=document.getElementById('bg-canvas');
const ctx=canvas.getContext('2d');
let W,H,particles=[];
function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight}
resize();window.addEventListener('resize',resize);
class P{
  constructor(){this.reset()}
  reset(){
    this.x=Math.random()*W;this.y=Math.random()*H;
    this.r=Math.random()*1.2+0.3;
    this.vx=(Math.random()-0.5)*0.18;this.vy=(Math.random()-0.5)*0.18;
    this.alpha=Math.random()*0.4+0.05;
    this.hue=Math.random()<0.7?210:160;
  }
  update(){
    this.x+=this.vx;this.y+=this.vy;
    if(this.x<0||this.x>W||this.y<0||this.y>H)this.reset();
  }
  draw(){
    ctx.beginPath();ctx.arc(this.x,this.y,this.r,0,Math.PI*2);
    ctx.fillStyle=`hsla(${this.hue},80%,65%,${this.alpha})`;
    ctx.fill();
  }
}
for(let i=0;i<90;i++)particles.push(new P());

/* grid lines */
function drawGrid(){
  ctx.strokeStyle='rgba(26,115,232,0.04)';ctx.lineWidth=1;
  for(let x=0;x<W;x+=60){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke()}
  for(let y=0;y<H;y+=60){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke()}
}

/* connections */
function drawConnections(){
  for(let i=0;i<particles.length;i++){
    for(let j=i+1;j<particles.length;j++){
      const dx=particles[i].x-particles[j].x,dy=particles[i].y-particles[j].y;
      const d=Math.sqrt(dx*dx+dy*dy);
      if(d<110){
        ctx.beginPath();
        ctx.strokeStyle=`rgba(74,156,246,${0.06*(1-d/110)})`;
        ctx.lineWidth=0.6;
        ctx.moveTo(particles[i].x,particles[i].y);
        ctx.lineTo(particles[j].x,particles[j].y);
        ctx.stroke();
      }
    }
  }
}

function loop(){
  ctx.clearRect(0,0,W,H);
  drawGrid();
  drawConnections();
  particles.forEach(p=>{p.update();p.draw()});
  requestAnimationFrame(loop);
}
loop();

/* ── TYPING ── */
const lines=[
  'RTL Design | Verilog HDL | SystemVerilog',
  'Functional Verification | SVA | Coverage',
  'ASIC Synthesis | Cadence Genus | STA',
  'HDLBits Practitioner | Always Building',
];
let li=0,ci=0,del=false;
const el=document.getElementById('typed-role');
function tick(){
  const s=lines[li];
  if(!del){
    el.innerHTML=s.slice(0,++ci)+'<span class="cursor-blink"></span>';
    if(ci===s.length){del=true;setTimeout(tick,2200);return}
    setTimeout(tick,52);
  } else {
    el.innerHTML=s.slice(0,--ci)+'<span class="cursor-blink"></span>';
    if(ci===0){del=false;li=(li+1)%lines.length;setTimeout(tick,350);return}
    setTimeout(tick,26);
  }
}
setTimeout(tick,1200);

/* ── SCROLL REVEAL ── */
const reveals=document.querySelectorAll('.reveal');
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target)}});
},{threshold:0.1});
reveals.forEach(r=>obs.observe(r));

/* ── COUNTER ANIMATION ── */
function animateCounter(el,target){
  let n=0;const step=Math.max(1,Math.ceil(target/50));
  const iv=setInterval(()=>{
    n=Math.min(n+step,target);el.textContent=n;
    if(n>=target)clearInterval(iv);
  },28);
}
const statObs=new IntersectionObserver(entries=>{
  if(entries[0].isIntersecting){
    ['s1','s2','s3','s4'].forEach(id=>{
      const el=document.getElementById(id);
      animateCounter(el,parseInt(el.dataset.target));
    });
    statObs.disconnect();
  }
},{threshold:0.3});
statObs.observe(document.querySelector('.stat-row'));

/* ── CONTRIBUTION GRID ── */
const grid=document.getElementById('contrib-grid');
const shades=['#0d1e35','#0c3060','#1a5296','#1a73e8','#4a9cf6','#7ab8ff'];
for(let w=0;w<53;w++){
  for(let d=0;d<7;d++){
    const v=Math.random();
    const ci=v<0.5?0:v<0.68?1:v<0.81?2:v<0.90?3:v<0.96?4:5;
    const cell=document.createElement('div');
    cell.className='contrib-cell';
    cell.style.background=shades[ci];
    grid.appendChild(cell);
  }
}

/* ── LANG BARS ── */
const langObs=new IntersectionObserver(entries=>{
  if(entries[0].isIntersecting){
    document.querySelectorAll('.lang-fill').forEach(b=>{b.style.width=b.dataset.w+'%'});
    langObs.disconnect();
  }
},{threshold:0.4});
langObs.observe(document.querySelector('.lang-list'));
</script>
</body>
</html>
